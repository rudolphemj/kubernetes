# 2 Appli NGINX + 2 INGRESS-NGINX



helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo update

kubectl create namespace ns-a

helm install ingress-a ingress-nginx/ingress-nginx \
  -n ns-a \
  --set controller.ingressClassResource.name=k8s.io/nginx-a \
  --set controller.ingressClass=nginx-a \
  --set controller.service.type=NodePort \
  --set controller.service.nodePorts.http=30080




kubectl create namespace ns-b

helm install ingress-b ingress-nginx/ingress-nginx \
  -n ns-b \
  --set controller.ingressClassResource.name=k8s.io/nginx-b \
  --set controller.ingressClass=nginx-b \
  --set controller.service.type=NodePort \
  --set controller.service.nodePorts.http=30081

========================================================================================

kubectl apply -f https://raw.githubusercontent.com/metallb/metallb/v0.14.5/config/manifests/metallb-native.yaml


helm install ingress-a ingress-nginx/ingress-nginx \
  -n ns-a \
  --set controller.ingressClassResource.name=nginx-a \
  --set controller.ingressClass=nginx-a \
  --set controller.service.type=LoadBalancer \
  --set controller.service.loadBalancerIP=192.168.1.240


helm install ingress-b ingress-nginx/ingress-nginx \
  -n ns-b \
  --set controller.ingressClassResource.name=nginx-b \
  --set controller.ingressClass=nginx-b \
  --set controller.service.type=LoadBalancer \
  --set controller.service.loadBalancerIP=192.168.1.241






